generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User_232035 {
  id                  String           @id @default(uuid())
  email               String?          @unique
  phone_number        String?          @unique
  full_name           String?          
  email_verified_at   DateTime?        
  phone_verified_at   DateTime?        
  registration_method String           
  account_status      String?          @default("active")
  last_login_at       DateTime?        
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  Session_232035      Session_232035[]
  Product_232035      Product_232035[]
}

model OTP_232035 {
  id           String    @id @default(uuid())
  identifier   String    
  user_id      String?   
  channel      String    
  purpose      String    
  otp_hash     String    
  expires_at   DateTime  
  attempt_count Int      @default(0)
  resend_count  Int      @default(0)
  consumed_at  DateTime? 
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([identifier])
  @@index([user_id])
  @@index([purpose])
  @@index([expires_at])
}

model Session_232035 {
  id                 String    @id @default(uuid())
  user_id            String    
  refresh_token_hash String    @db.Text
  device_information String?   @db.Text
  ip_address         String?   
  expires_at         DateTime  
  revoked_at         DateTime? 
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  user User_232035 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@index([revoked_at])
}

model Product_232035 {
  id                   String              @id @default(uuid())
  name                 String
  description          String              @db.Text
  price                Int
  original_price       Int
  discount             Int                 @default(0)
  rating               Float               @default(5.0)
  sold                 Int                 @default(0)
  sold_label           String?
  location             String
  promo_text           String              @default("")
  free_shipping        Boolean             @default(false)
  meta_icon            String              @default("none")
  is_official          Boolean             @default(false)
  is_power_shop        Boolean             @default(false)
  use_price_badge      Boolean             @default(false)
  show_discount_beside Boolean             @default(false)
  user_id              String
  created_at           DateTime            @default(now())
  updated_at           DateTime            @updatedAt

  user                 User_232035         @relation(fields: [user_id], references: [id])
  images               ProductImage_232035[]

  @@index([user_id])
  @@index([created_at])
}

model ProductImage_232035 {
  id            String   @id @default(uuid())
  product_id    String
  url           String
  storage_path  String
  file_name     String
  mime_type     String
  file_size     Int
  is_primary    Boolean  @default(false)
  created_at    DateTime @default(now())

  product       Product_232035 @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}
